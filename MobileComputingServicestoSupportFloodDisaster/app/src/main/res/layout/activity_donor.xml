<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".user.DonerActivity">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Add your Donation"
        android:padding="10dp"
        android:textColor="@color/black"
        android:textSize="18sp"
        android:textStyle="bold"
        android:gravity="center"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:paddingEnd="20sp"
        android:text="Please send precription photo"
        android:textColor="@color/black"
        tools:ignore="HardcodedText" />

    <LinearLayout
        style="@style/edittext"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:backgroundTint="@color/white">

        <LinearLayout

            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="0.5"
            android:orientation="vertical">

            <TextView
                style="@style/texthead"
                android:layout_height="wrap_content"
                android:text="Name *"
                android:textStyle="bold"
                tools:ignore="HardcodedText" />

            <TextView
                android:id="@+id/name"
                style="@style/headtext"
                android:textSize="12sp" />

            <TextView
                style="@style/texthead"
                android:layout_height="wrap_content"
                android:text="Mail-id *"
                android:textStyle="bold"
                tools:ignore="HardcodedText" />

            <TextView
                android:id="@+id/mailid2"
                style="@style/headtext"
                android:text="Text@gail.com"
                android:textSize="12sp"
                tools:ignore="HardcodedText" />

            <TextView
                style="@style/texthead"
                android:layout_height="wrap_content"
                android:text="Mobile Number"
                android:textStyle="bold"
                tools:ignore="HardcodedText" />

            <TextView
                android:id="@+id/mobile"
                style="@style/headtext"
                android:text="0000000000"
                android:textSize="12sp"
                tools:ignore="HardcodedText" />

            <TextView
                style="@style/texthead"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:text="Address"
                tools:ignore="HardcodedText" />

            <TextView
                android:id="@+id/adress"
                style="@style/headtext"
                android:text="Tiupati"
                android:visibility="gone"
                android:textSize="15sp"
                tools:ignore="HardcodedText" />

        </LinearLayout>

        <ImageView
            android:id="@+id/seton"
            android:layout_width="0dp"
            android:layout_height="158dp"
            android:layout_gravity="center"
            android:layout_weight="0.5"
            android:background="@drawable/line"
            android:padding="10dp"
            android:src="@drawable/camera"
            tools:ignore="ContentDescription" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="150dp"
        android:layout_margin="9dp"
        android:background="@drawable/line">

        <EditText
            android:id="@+id/discription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="@color/black"
            android:hint="Description"
            android:textColor="@color/black"
            tools:ignore="HardcodedText" />

    </LinearLayout>

    <EditText
        android:id="@+id/disnmae"
        style="@style/headtext"
        android:layout_marginStart="9dp"
        android:layout_marginEnd="9dp"
        android:backgroundTint="@color/black"
        android:hint="Type"
        android:text=""
        tools:ignore="HardcodedText" />

    <Spinner
        android:id="@+id/spinner"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_margin="5dp"
        android:entries="@array/typDonation" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/submit"
        android:layout_width="150dp"
        android:layout_height="50dp"
        android:layout_gravity="center"
        android:layout_marginTop="10dp"
        android:background="@drawable/line"
        android:backgroundTint="@color/teal_200"
        android:text="Submit"
        android:textAllCaps="false"
        android:textSize="20sp"
        tools:ignore="HardcodedText" />
</LinearLayout>

