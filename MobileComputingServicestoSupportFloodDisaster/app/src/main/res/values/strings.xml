<resources>
    <string name="app_name">FloodAid</string>

    <style name="card">
        <item name="android:foreground">?android:attr/selectableItemBackground</item>
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_weight">0.5</item>
        <item name="android:layout_marginEnd">9dp</item>
        <item name="android:layout_height">60dp</item>
        <item name="cardBackgroundColor">@color/teal_200</item>
        <item name="cardCornerRadius">9dp</item>
    </style>

    <style name="text">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:gravity">center</item>
        <item name="android:paddingEnd">20dp</item>
        <item name="android:textSize">17sp</item>
        <item name="android:textColor">@color/black</item>
    </style>

    <style name="edittext">
        <item name="android:layout_marginTop">5dp</item>
        <item name="android:layout_marginStart">9dp</item>
        <item name="android:layout_marginEnd">9dp</item>
        <item name="android:paddingStart">9dp</item>
        <item name="android:backgroundTint">@color/teal_200</item>
        <item name="android:background">@drawable/wholecurve</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">50dp</item>
    </style>

    <style name="texthead">
        <item name="android:textColor">@color/black</item>
        <item name="android:textSize">17sp</item>
        <item name="android:gravity">start</item>
        <item name="android:paddingStart">5dp</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
    </style>

    <style name="headtext">
        <item name="android:textSize">18sp</item>
        <item name="android:paddingStart">5dp</item>
        <item name="android:text">Test</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
    </style>

    <style name="textview">
        <item name="android:layout_width">match_parent</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:layout_marginStart">9dp</item>
        <item name="android:layout_marginEnd">9dp</item>
        <item name="android:layout_height">wrap_content</item>
    </style>

    <style name="btn">
        <item name="android:layout_width">150dp</item>
        <item name="android:layout_gravity">center</item>
        <item name="android:layout_marginTop">10dp</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:background">@drawable/line</item>
        <item name="android:backgroundTint">@color/teal_200</item>
        <item name="android:layout_height">50dp</item>
    </style>
</resources>